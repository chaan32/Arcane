# Copy this file to .env.ec2 on the EC2 host.
# Do not commit the real .env.ec2 file.

# Public frontend origin deployed on Vercel.
FRONTEND_ORIGIN=https://your-arcane-frontend.vercel.app
APP_CORS_ALLOWED_ORIGIN_PATTERNS=https://your-arcane-frontend.vercel.app
OAUTH2_SUCCESS_REDIRECT_URI=https://your-arcane-frontend.vercel.app/oauth/callback
OAUTH2_FAILURE_REDIRECT_URI=https://your-arcane-frontend.vercel.app/oauth/callback

# Spring datasource credentials.
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-this-db-password

# JWT.
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRATION=3600000
JWT_PASSWORD=change-this-jwt-password

# Riot / Data Dragon.
RIOT_API_KEY=RGAPI-change-this
RIOT_PATCH_VERSION=latest

# OAuth providers.
GOOGLE_CLIENT_ID=change-this
GOOGLE_CLIENT_SECRET=change-this
NAVER_CLIENT_ID=change-this
NAVER_CLIENT_SECRET=change-this

# API to AI score transport. Keep kafka when AI score requests should flow through Kafka.
MODELING_TRANSPORT=kafka
MODELING_KAFKA_TIMEOUT_MS=3000

# Optional image names if you push images to a registry.
ARCANE_API_IMAGE=arcane-api:ec2
ARCANE_WORKER_IMAGE=arcane-worker:ec2
ARCANE_AI_IMAGE=arcane-ai:ec2

# Optional monitoring account.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password
