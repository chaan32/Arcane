ARCANE_DB_HOST=127.0.0.1
ARCANE_DB_PORT=3307
ARCANE_DB_NAME=arcane_db
ARCANE_DB_USER=root
ARCANE_DB_PASSWORD=arcane1234

# DeepLOL 페이지를 너무 빠르게 때리지 않도록 요청 사이에 쉬는 시간.
DEEPLOL_CRAWL_DELAY_SECONDS=2.0

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AI_KAFKA_ENABLED=true
AI_SCORE_REQUEST_TOPIC=arcane.ai.score.requested
AI_SCORE_COMPLETED_TOPIC=arcane.ai.score.completed
AI_SCORE_FAILED_TOPIC=arcane.ai.score.failed
AI_SCORE_GROUP_ID=arcane-ai-score-server
