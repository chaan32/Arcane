# Vercel environment variables.
# NEXT_PUBLIC_API_URL must be the public EC2 API address.
# Example without a domain: http://your-ec2-public-ip:8080
# Example with a reverse proxy: https://api.your-domain.com
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# Optional. If omitted, the frontend falls back to the version configured in code.
NEXT_PUBLIC_DDRAGON_VERSION=latest
